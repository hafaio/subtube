{
  "compilerOptions": {
    "module": "nodenext",
    "target": "es2023",
    "moduleResolution": "nodenext",
    "outDir": "lib",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noImplicitReturns": true
  },
  "include": ["src"]
}
